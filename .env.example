# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_WEB_CLIENT_ID: Optional unless you want Google Sign In to work
# Find this in your google-services.json file, under oauth_client client_id where client_type is 3. 
# Alternatively, find it in Firebase Console -> Authentication -> Sign-in methods -> Google -> Web SDK configuration -> Web client ID.
FIREBASE_WEB_CLIENT_ID=mock_client_id
